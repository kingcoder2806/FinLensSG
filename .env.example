# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis (30-min rate caching)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Supabase (rate history + user alerts)
NEXT_PUBLIC_SUPABASE_URL=https://....supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# Database URL (for Prisma)
DATABASE_URL=postgresql://...

# Optional: App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for /api/check-rates (the automated rate updater).
# Send it as `x-check-secret`, `Authorization: Bearer <secret>`, or `?secret=`.
# Omit in dev to leave the endpoint open.
CHECK_RATES_SECRET=

# Vercel Cron auth. When set, Vercel attaches `Authorization: Bearer <CRON_SECRET>`
# to scheduled requests (see vercel.json). The updater accepts either secret.
CRON_SECRET=
